# Conecta — variables de entorno
#
# Expo expone automáticamente las variables EXPO_PUBLIC_* en la app.
# Copia este archivo como .env.local y rellena los valores.
# .env.local está en .gitignore — no se sube al repo.
#
# IMPORTANTE: tras cambiar .env.local, reinicia Expo con:
#   npx expo start -c    (limpia caché y recoge nuevos env vars)

# URL del bridge de Idefix (sin / final)
# Desarrollo local con túnel SSH: http://127.0.0.1:18790
# iPhone con túnel SSH en LAN:  http://192.168.X.X:18790
EXPO_PUBLIC_CONECTA_BRIDGE_URL=http://127.0.0.1:18790

# Secreto del bridge (generado con: openssl rand -hex 16)
EXPO_PUBLIC_CONECTA_BRIDGE_SECRET=pon-tu-secreto-aqui

# Usar API real (false) o mock (true)
# Cambiar a false solo cuando el bridge esté corriendo y accesible
EXPO_PUBLIC_CONECTA_USE_MOCK=true